PORT=3001
NODE_ENV=development

# Deadlock community API
DEADLOCK_API_BASE_URL=https://api.deadlock-api.com

# Valve CDN base (constructed dynamically with match_id + salt)
VALVE_CDN_BASE_URL=https://replay*.valve.net/1422450

# Temp directory for .dem files (relative to server root)
TEMP_DIR=./temp

# Supabase Server Setup
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhb...
SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# Direct DB connection for setup-supabase.js schema migrations only
# Format: postgresql://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<your-project-ref>.supabase.co:5432/postgres

# Optional: Redis cache URL
# REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Error Monitoring (Sentry)
# SENTRY_DSN=https://your-key@sentry.io/project-id

# CORS Whitelist (Optional, comma-separated)
# CORS_ORIGIN=https://aftermatch.xyz,https://www.aftermatch.xyz

# Frontend API URL (For standalone client deployment)
# Used when the client is NOT served by the same origin as the backend.
# Defaults to '/api' in monorepo/unified deployments.
# VITE_API_BASE_URL=http://localhost:3001/api
