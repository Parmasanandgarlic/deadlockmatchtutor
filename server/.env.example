PORT=3001
NODE_ENV=development

# Deadlock community API
DEADLOCK_API_BASE_URL=https://deadlock-api.com

# Valve CDN base (constructed dynamically with match_id + salt)
VALVE_CDN_BASE_URL=https://replay*.valve.net/1422450

# Temp directory for .dem files (relative to server root)
TEMP_DIR=./temp

# Optional: Redis cache URL
# REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
