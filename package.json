{
  "name": "deadlock-aftermatch",
  "version": "1.0.1",
  "description": "Comprehensive post-match analyzer for Deadlock",
  "type": "commonjs",
  "homepage": "https://www.aftermatch.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Parmasanandgarlic/deadlockmatchtutor.git"
  },
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "generate:openapi": "node scripts/generate-openapi.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run build -w client",
    "vercel-build": "npm run build -w client && mkdir -p dist && cp -rv client/dist/* dist/",
    "start": "npm run start --workspace=server",
    "install:all": "npm install",
    "test": "npm run typecheck && node tests/run-all.js",
    "test:unit": "node tests/unit/helpers.test.js && node tests/unit/scoring.test.js && node tests/unit/insights.test.js && node tests/unit/constants.test.js && node tests/unit/trends.test.js && node tests/unit/deadlockAdapter.test.js",
    "test:component": "node tests/component/validation.test.js && node tests/component/errorHandler.test.js && node tests/component/securityMiddleware.test.js",
    "test:sast": "node tests/sast/sast-scan.js",
    "test:integration": "node tests/integration/pipeline.test.js",
    "test:api": "node tests/api/api.test.js",
    "test:db": "node tests/database/database.test.js",
    "test:e2e": "node tests/e2e/smoke.test.js",
    "test:ci:api": "node tests/ci/api-smoke.test.js",
    "test:ci:browser": "node tests/ci/browser-smoke.test.js",
    "test:regression": "node tests/regression/regression.test.js",
    "test:compliance": "node tests/compliance/compliance.test.js",
    "test:load": "node tests/performance/load.test.js",
    "test:stress": "node tests/performance/stress.test.js",
    "test:dast": "node tests/security/dast.test.js",
    "test:failover": "node tests/failover/failover.test.js"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.103.2",
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "deadlock_api_client": "file:./server/deadlock_api_client",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^8.0.4",
    "passport": "^0.7.0",
    "passport-steam": "^1.0.18",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.39",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^8.2.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "20.x"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@rollup/rollup-linux-x64-musl": "4.60.1"
  }
}
