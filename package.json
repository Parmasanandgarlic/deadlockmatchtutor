{
  "name": "deadlock-match-tutor",
  "version": "1.0.0",
  "description": "Comprehensive post-match analyzer for Deadlock",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "install:all": "npm install",
    "test": "node tests/run-all.js",
    "test:unit": "node tests/unit/helpers.test.js && node tests/unit/scoring.test.js",
    "test:component": "node tests/component/validation.test.js && node tests/component/errorHandler.test.js",
    "test:sast": "node tests/sast/sast-scan.js",
    "test:integration": "node tests/integration/pipeline.test.js",
    "test:api": "node tests/api/api.test.js",
    "test:db": "node tests/database/database.test.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
