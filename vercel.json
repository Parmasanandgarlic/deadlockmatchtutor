{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build -w client",
  "outputDirectory": "client/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/og/:matchId/:accountId", "destination": "/api/og/[matchId]/[accountId]" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/robots.txt", "destination": "/api/index" },
    { "source": "/", "destination": "/api/index" },
    { "source": "/about", "destination": "/api/index" },
    { "source": "/faq", "destination": "/api/index" },
    { "source": "/resources", "destination": "/api/index" },
    { "source": "/privacy", "destination": "/api/index" },
    { "source": "/matches/(.*)", "destination": "/api/index" },
    { "source": "/player/(.*)", "destination": "/api/index" },
    { "source": "/dashboard/(.*)", "destination": "/api/index" },
    { "source": "/report/(.*)", "destination": "/api/index" },
    { "source": "/guide/(.*)", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self'; script-src-attr 'none'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; connect-src 'self' https://api.deadlock-api.com https://assets.deadlock-api.com https://steamcommunity.com https://vitals.vercel-insights.com; img-src 'self' data: https://assets-bucket.deadlock-api.com https://assets.deadlock-api.com https://deadlock-api.com; font-src 'self' https://fonts.gstatic.com; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 0 * * *"
    }
  ],
  "env": {
    "DEPLOYMENT_VERSION": "1.0.2-canonical-layout"
  }
}
