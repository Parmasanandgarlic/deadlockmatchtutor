{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "server/**/*.js",
    "scripts/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "client",
    "dist",
    "temp-openapi",
    "server/deadlock_api_client"
  ]
}
